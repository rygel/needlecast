# Screenshot tour image.
# Builds the fat JAR, starts Xvfb, runs ScreenshotTour, and copies PNGs to /screenshots.
#
# Usage (outputs PNGs to ./screenshots on the host):
#   docker build -f Dockerfile.screenshots -t needlecast-screenshots .
#   docker run --rm -v "$(pwd)/screenshots:/screenshots" needlecast-screenshots

FROM maven:3.9-eclipse-temurin-21-jammy@sha256:7f8422bd81f19b9035007a75e2f82272b09af64db08848d7d4e93302466e8b6f

# X11 / virtual framebuffer + font dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        xvfb \
        libxtst6 \
        libxrender1 \
        libxi6 \
        libx11-6 \
        libxext6 \
        fonts-dejavu-core \
        fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Maven settings for GitHub Packages auth (sparkle4j)
ARG GITHUB_ACTOR=""
ARG GITHUB_TOKEN=""
RUN mkdir -p /root/.m2 && \
    if [ -n "$GITHUB_TOKEN" ]; then \
      printf '<settings><servers><server><id>github-sparkle4j</id><username>%s</username><password>%s</password></server></servers></settings>' \
        "$GITHUB_ACTOR" "$GITHUB_TOKEN" > /root/.m2/settings.xml; \
    else \
      echo '<settings/>' > /root/.m2/settings.xml; \
    fi

# Resolve dependencies as a cached layer
COPY pom.xml .
COPY needlecast-desktop/pom.xml needlecast-desktop/pom.xml
COPY needlecast-web/pom.xml needlecast-web/pom.xml
RUN mvn -B -pl needlecast-desktop -am dependency:resolve dependency:resolve-plugins -q

# Build fat JAR (skip tests — this image is only for screenshots)
COPY . .
RUN mvn -pl needlecast-desktop -am package -DskipTests -T 4 -q

# Run the screenshot tour inside Xvfb and copy results to /screenshots
CMD ["sh", "-c", "\
    mkdir -p /screenshots && \
    Xvfb :99 -screen 0 1280x900x24 -nolisten tcp & \
    XVFB_PID=$! ; \
    sleep 1 ; \
    timeout 180 env DISPLAY=:99 java \
        -Djava.awt.headless=false \
        -Dawt.useSystemAAFontSettings=lcd \
        -Dswing.aatext=true \
        -cp needlecast-desktop/target/needlecast.jar \
        io.github.rygel.needlecast.tools.ScreenshotTourKt \
        /screenshots ; \
    STATUS=$? ; \
    kill \"$XVFB_PID\" 2>/dev/null ; \
    exit $STATUS \
"]
